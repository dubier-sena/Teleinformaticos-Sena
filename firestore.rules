rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Colecciones del portal SENA — acceso abierto via API key publica.
    // La seguridad se basa en que la API key no permite operaciones
    // destructivas masivas y el plan Spark limita lecturas/escrituras diarias.
    match /sena_portal_users/{usernameKey} {
      allow read, write: if true;
    }

    match /sena_portal_progress/{usernameKey} {
      allow read, write: if true;
    }

    match /sena_portal_guide_state/{docId} {
      allow read, write: if true;
    }

    match /sena_portal_calendar/{calendarId} {
      allow read, write: if true;
    }

    match /sena_portal_tutoring_bookings/{bookingId} {
      allow read, write: if true;
    }

    // Bloquear cualquier otra coleccion no prevista
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
