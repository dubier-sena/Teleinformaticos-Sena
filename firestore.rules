rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Seguridad por defecto:
    // Este cliente estatico no debe operar con Firestore abierto.
    // Solo habilita accesos cuando exista una capa segura adicional
    // (Firebase Auth o un backend intermedio).
    match /sena_portal_users/{usernameKey} {
      allow read, write: if false;
    }

    match /sena_portal_progress/{usernameKey} {
      allow read, write: if false;
    }

    match /sena_portal_calendar/{calendarId} {
      allow read, write: if false;
    }

    match /sena_portal_guide_state/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
